generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("PLAYER")
  createdAt DateTime @default(now())

  quizzes         Quiz[]
  organizedGames  QuizSession[]  @relation("SessionOrganizer")
  gameResults     SessionResult[]
}

model Quiz {
  id              Int    @id @default(autoincrement())
  title           String
  category        String
  rules           String?
  timePerQuestion Int

  creatorId Int
  creator   User @relation(fields: [creatorId], references: [id])

  questions Question[]
  rooms     Room[]
  sessions  QuizSession[]
}

model Room {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  status    String   @default("WAITING")
  createdAt DateTime @default(now())

  quizId Int
  quiz   Quiz @relation(fields: [quizId], references: [id])
}

model Question {
  id       Int     @id @default(autoincrement())
  text     String
  type     String
  imageUrl String?

  quizId Int
  quiz   Quiz @relation(fields: [quizId], references: [id])

  answers Answer[]
}

model Answer {
  id        Int     @id @default(autoincrement())
  text      String
  isCorrect Boolean @default(false)

  questionId Int
  question   Question @relation(fields: [questionId], references: [id])
}

model QuizSession {
  id         Int       @id @default(autoincrement())
  roomCode   String
  status     String    @default("ACTIVE")
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  quizId Int
  quiz   Quiz @relation(fields: [quizId], references: [id])

  organizerId Int
  organizer   User @relation("SessionOrganizer", fields: [organizerId], references: [id])

  results SessionResult[]
}

model SessionResult {
  id             Int      @id @default(autoincrement())
  score          Int
  totalQuestions Int
  place          Int
  createdAt      DateTime @default(now())

  sessionId Int
  session   QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
}